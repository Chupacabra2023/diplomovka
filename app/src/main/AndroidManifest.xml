<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Diplomovka_kotlin">

        <!-- Google Maps API key — vlož do res/values/google_maps_api.xml -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_key" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth flow host (Landing / Login / Register / ResetPassword sú Fragmenty) -->
        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="false" />

        <!-- Hlavná mapa -->
        <activity
            android:name=".ui.map.MapActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Event screens -->
        <activity android:name=".ui.events.EventDetailActivity" android:exported="false" />
        <activity android:name=".ui.events.EventCreationInformationActivity" android:exported="false" />

        <!-- Drawer / navigácia z mapy -->
        <activity android:name=".ui.settings.ProfileSettingsActivity" android:exported="false" />
        <activity android:name=".ui.settings.SettingsActivity" android:exported="false" />
        <activity android:name=".ui.events.MyCreatedEventsActivity" android:exported="false" />
        <activity android:name=".ui.events.MyVisitedEventsActivity" android:exported="false" />
        <activity android:name=".ui.events.RecommendedEventsActivity" android:exported="false" />
        <activity android:name=".ui.events.MyInvitationsActivity" android:exported="false" />
        <activity android:name=".ui.settings.HelpActivity" android:exported="false" />
        <activity android:name=".ui.settings.LogoutActivity" android:exported="false" />

    </application>

</manifest>
