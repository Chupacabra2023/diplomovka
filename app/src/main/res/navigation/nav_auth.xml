<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_auth"
    app:startDestination="@id/landingFragment">

    <fragment
        android:id="@+id/landingFragment"
        android:name="com.example.diplomovka_kotlin.ui.auth.LandingFragment"
        android:label="Landing"
        tools:layout="@layout/activity_landing">
        <action
            android:id="@+id/action_landing_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_landing_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.diplomovka_kotlin.ui.auth.LoginFragment"
        android:label="Prihlásenie"
        tools:layout="@layout/activity_login">
        <action
            android:id="@+id/action_login_to_resetPassword"
            app:destination="@id/resetPasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.diplomovka_kotlin.ui.auth.RegisterFragment"
        android:label="Registrácia"
        tools:layout="@layout/activity_register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.example.diplomovka_kotlin.ui.auth.ResetPasswordFragment"
        android:label="Reset hesla"
        tools:layout="@layout/activity_reset_password" />

</navigation>
